# ── Render-style keys (used by render.yaml, also accepted locally) ─────────
SECRET_KEY=change-me-to-a-50-char-random-string
DEBUG=True

# ── Legacy keys (still accepted as fallbacks by settings_base.py) ──────────
DJANGO_ENV=dev
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_TIME_ZONE=Asia/Kolkata

# ── Database ───────────────────────────────────────────────────────────────
# Local dev: SQLite (default, no change needed)
# Render: DATABASE_URL is auto-injected from the linked evoting-db instance
DATABASE_URL=sqlite:///db.sqlite3

# ── Cloud Media Storage (Cloudinary) ──────────────────────────────────────
# Get this from: https://cloudinary.com → Dashboard → API Keys
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Leave empty to use local filesystem storage (development)
CLOUDINARY_URL=
